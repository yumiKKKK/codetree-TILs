        for(int[] ar : arr) {
            for(int a : ar) {
                System.out.print(a + " ");
            }
            System.out.println();
        }
        System.out.println();
    }

    public static void print(String[][] arr) {
        for(String[] ar : arr) {
            for(String a : ar) {
                System.out.print(a + " ");
            }
            System.out.println();
        }
        System.out.println();
    }

}
